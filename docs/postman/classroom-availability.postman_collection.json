    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Login as Faculty",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json?.data?.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "}",
                  "if (json?.data?.user?.id) {",
                  "  pm.collectionVariables.set('currentUserId', json.data.user.id);",
                  "}",
                  "if (json?.data?.user?.role) {",
                  "  pm.collectionVariables.set('currentUserRole', json.data.user.role);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-request-id",
                "value": "{{$guid}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{facultyEmail}}\",\n  \"password\": \"{{devPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Logs in as FACULTY and stores access token in collection variable accessToken."
          },
          "response": []
        },
